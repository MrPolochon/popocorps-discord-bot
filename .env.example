# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration (Railway provides this automatically)
DATABASE_URL=postgresql://username:password@host:port/database

# Flask Session Secret
SESSION_SECRET=your_random_secret_key_here

# Dashboard web (Flask)
DASHBOARD_PASSWORD=your_dashboard_password_here
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret
# URL publique Railway, sans slash final (ex: https://xxx.up.railway.app)
DASHBOARD_BASE_URL=https://your-app.up.railway.app

# Optional: Google Gemini (IA chat)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Logging Level
LOG_LEVEL=INFO